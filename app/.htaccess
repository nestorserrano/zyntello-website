Options -Indexes -MultiViews
RewriteEngine On

# Evitar doble procesamiento: si la URL ya apunta dentro de /public/, detenerse
RewriteCond %{REQUEST_URI} ^/[^/]+/public/
RewriteRule ^ - [L]

# Servir archivos estáticos (CSS, JS, imágenes, fuentes) desde [slug]/public/
# si el archivo físico existe allí
RewriteCond %{DOCUMENT_ROOT}/$1/public/$2 -f
RewriteRule ^([^/]+)/(.+)$ $1/public/$2 [L,QSA,NC]

# Rutas dinámicas: delegar al front controller de Laravel
# No se usa !-d porque cada [slug]/ es un directorio real en el servidor
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^/]+)(/.*)?$ $1/public/index.php [L,QSA]
